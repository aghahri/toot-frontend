NEXT_PUBLIC_API_BASE_URL=http://api.tootapp.net
NEXT_PUBLIC_MEDIA_BASE_URL=http://media.tootapp.net

# When true, shows a dev-only OTP toast after auth/request-otp (login). Never enable in production.
# NEXT_PUBLIC_DEV_OTP=true

# Voice/WebRTC debug overlay: production builds only when set to 1 (rebuild after change). In `next dev`, on by default; set to 0 to hide.
# NEXT_PUBLIC_VOICE_CALL_DEBUG=1

# Optional: APK download for landing CTA — full HTTPS URL or same-site path, e.g. /downloads/toot-android-beta.apk
# (file must exist under public/downloads/ before build when using a path). CTA hidden if unset.
# NEXT_PUBLIC_ANDROID_APK_URL=/downloads/toot-android-beta.apk

# Capacitor Android shell: HTTPS origin of this Next app (no trailing slash). Required when running `npm run android:sync`.
# CAPACITOR_WEB_ORIGIN=https://app.example.com

