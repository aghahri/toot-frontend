NEXT_PUBLIC_API_BASE_URL=http://api.tootapp.net
NEXT_PUBLIC_MEDIA_BASE_URL=http://media.tootapp.net

# When true, shows a dev-only OTP toast after auth/request-otp (login). Never enable in production.
# NEXT_PUBLIC_DEV_OTP=true

# Voice call WebRTC debug overlay (off in production unless set). In development, set to 0 to hide.
# NEXT_PUBLIC_VOICE_CALL_DEBUG=1

# Optional: HTTPS (or http) URL to the Android APK. When set, the landing page shows a beta Android download CTA.
# NEXT_PUBLIC_ANDROID_APK_URL=https://example.com/releases/toot-android-beta.apk

